# Production environment template
# Copy to .env.backend.local on the server and fill in real values.
# NEVER commit .env.backend.local — it is gitignored.

# Database
ConnectionStrings__Platform=Host=postgres;Port=5432;Database=platform;Username=platform;Password=<CHANGE_ME>

# JWT signing key (generate a random 64+ character string)
Jwt__SigningKey=<GENERATE_RANDOM_64_CHAR_STRING>

# Admin credentials
AdminSecurity__UserName=<CHANGE_ME>
AdminSecurity__Password=<CHANGE_ME>

# SMTP password for email verification
EmailVerification__SmtpPassword=<CHANGE_ME>
